# Leave any line empty to run that feature in demo mode.
# Real values activate the feature in production.

# ── Supabase — auth, contact form, bookings, dashboard ────────────────
# Example: https://abcdefgh.supabase.co  +  ey...long-anon-key...
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Supabase service role — required ONLY for /admin ────────────────
# WARNING: secret. Never expose to the browser. Server-only.
SUPABASE_SERVICE_ROLE_KEY=

# Comma-separated emails authorized to access /admin
ADMIN_EMAILS=

# ── Anthropic — /consultant chat ────────────────────────────────────
# Get at: https://console.anthropic.com
ANTHROPIC_API_KEY=

# ── Resend — optional, email notifications on contact + booking ─────
RESEND_API_KEY=
EMAIL_FROM="Emad <onboarding@resend.dev>"
EMAIL_TO_ADMIN=

# ── Public site URL — used for OAuth redirects, sitemap, RSS, OG ────
# In production set this to your Vercel URL (https://your-app.vercel.app)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Set to "true" to bypass API rate limits (load tests only) ───────
RATE_LIMIT_DISABLED=
